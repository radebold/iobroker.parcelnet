{
  "type": "tabs",
  "items": {
    "mainTab": {
      "type": "panel",
      "label": {
        "en": "General",
        "de": "Allgemein"
      },
      "items": {
        "apiKey": {
          "type": "password",
          "label": {
            "en": "Parcel API key",
            "de": "Parcel API-Key"
          },
          "help": {
            "en": "Create the key at web.parcelapp.net.",
            "de": "Den Schlüssel erzeugst du unter web.parcelapp.net."
          },
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "filterMode": {
          "type": "select",
          "label": {
            "en": "Filter mode",
            "de": "Filtermodus"
          },
          "options": [
            { "label": { "en": "Active deliveries", "de": "Aktive Lieferungen" }, "value": "active" },
            { "label": { "en": "Recent deliveries", "de": "Letzte Lieferungen" }, "value": "recent" }
          ],
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "pollIntervalMinutes": {
          "type": "number",
          "label": {
            "en": "Polling interval (minutes)",
            "de": "Polling-Intervall (Minuten)"
          },
          "min": 3,
          "step": 1,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "requestTimeoutMs": {
          "type": "number",
          "label": {
            "en": "Request timeout (ms)",
            "de": "Request-Timeout (ms)"
          },
          "min": 5000,
          "step": 1000,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "maxItemsInHtml": {
          "type": "number",
          "label": {
            "en": "Max items in VIS HTML",
            "de": "Max. Einträge im VIS-HTML"
          },
          "min": 1,
          "step": 1,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "showTrackingNumberInHtml": {
          "type": "checkbox",
          "label": {
            "en": "Show tracking number in VIS HTML",
            "de": "Trackingnummer im VIS-HTML anzeigen"
          },
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "showDemoWhenEmpty": {
          "type": "checkbox",
          "label": {
            "en": "Show demo carriers when API returns no deliveries",
            "de": "Demo-Carrier anzeigen, wenn die API keine Sendungen liefert"
          },
          "help": {
            "en": "Only affects the VIS HTML states. Real delivery states stay empty.",
            "de": "Betrifft nur die VIS-HTML-States. Echte Liefer-States bleiben leer."
          },
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "logRawResponse": {
          "type": "checkbox",
          "label": {
            "en": "Log raw API response (debug)",
            "de": "Rohantwort der API loggen (Debug)"
          },
          "sm": 12,
          "md": 4,
          "lg": 3
        }
      }
    },
    "carrierTab": {
      "type": "panel",
      "label": {
        "en": "Carrier logos",
        "de": "Carrier-Logos"
      },
      "items": {
        "logoInfo": {
          "type": "staticText",
          "text": {
            "en": "Upload your own logo files in the selected folder and choose them per carrier below. The adapter uses the selected file path directly in the VIS HTML.",
            "de": "Lade deine eigenen Logo-Dateien in den gewählten Ordner hoch und wähle sie unten pro Carrier aus. Der Adapter nutzt den ausgewählten Dateipfad direkt im VIS-HTML."
          },
          "sm": 12,
          "md": 12,
          "lg": 12
        },
        "logoFolder": {
          "type": "text",
          "label": {
            "en": "Logo folder",
            "de": "Logo-Ordner"
          },
          "help": {
            "en": "Example: /vis.0/main/img/parcelnet",
            "de": "Beispiel: /vis.0/main/img/parcelnet"
          },
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "carrierLogo_parcel": {
          "type": "fileSelector",
          "label": { "en": "Default / fallback logo", "de": "Standard-/Fallback-Logo" },
          "sm": 12, "md": 6, "lg": 4,
          "root": "dataFiles",
          "folder": "data:vis.0/main/img/parcelnet",
          "allowUpload": true,
          "allowCreateFolder": true,
          "pattern": "(?i).+\\.(png|svg|jpg|jpeg|webp)$"
        },
        "carrierLogo_dhl": {
          "type": "fileSelector",
          "label": { "en": "DHL logo", "de": "DHL-Logo" },
          "sm": 12, "md": 6, "lg": 4,
          "root": "dataFiles",
          "folder": "data:vis.0/main/img/parcelnet",
          "allowUpload": true,
          "pattern": "(?i).+\\.(png|svg|jpg|jpeg|webp)$"
        },
        "carrierLogo_hermes": {
          "type": "fileSelector",
          "label": { "en": "Hermes logo", "de": "Hermes-Logo" },
          "sm": 12, "md": 6, "lg": 4,
          "root": "dataFiles",
          "folder": "data:vis.0/main/img/parcelnet",
          "allowUpload": true,
          "pattern": "(?i).+\\.(png|svg|jpg|jpeg|webp)$"
        },
        "carrierLogo_dpd": {
          "type": "fileSelector",
          "label": { "en": "DPD logo", "de": "DPD-Logo" },
          "sm": 12, "md": 6, "lg": 4,
          "root": "dataFiles",
          "folder": "data:vis.0/main/img/parcelnet",
          "allowUpload": true,
          "pattern": "(?i).+\\.(png|svg|jpg|jpeg|webp)$"
        },
        "carrierLogo_ups": {
          "type": "fileSelector",
          "label": { "en": "UPS logo", "de": "UPS-Logo" },
          "sm": 12, "md": 6, "lg": 4,
          "root": "dataFiles",
          "folder": "data:vis.0/main/img/parcelnet",
          "allowUpload": true,
          "pattern": "(?i).+\\.(png|svg|jpg|jpeg|webp)$"
        },
        "carrierLogo_amazon": {
          "type": "fileSelector",
          "label": { "en": "Amazon logo", "de": "Amazon-Logo" },
          "sm": 12, "md": 6, "lg": 4,
          "root": "dataFiles",
          "folder": "data:vis.0/main/img/parcelnet",
          "allowUpload": true,
          "pattern": "(?i).+\\.(png|svg|jpg|jpeg|webp)$"
        },
        "carrierLogo_gls": {
          "type": "fileSelector",
          "label": { "en": "GLS logo", "de": "GLS-Logo" },
          "sm": 12, "md": 6, "lg": 4,
          "root": "dataFiles",
          "folder": "data:vis.0/main/img/parcelnet",
          "allowUpload": true,
          "pattern": "(?i).+\\.(png|svg|jpg|jpeg|webp)$"
        },
        "carrierLogo_deutschepost": {
          "type": "fileSelector",
          "label": { "en": "Deutsche Post logo", "de": "Deutsche-Post-Logo" },
          "sm": 12, "md": 6, "lg": 4,
          "root": "dataFiles",
          "folder": "data:vis.0/main/img/parcelnet",
          "allowUpload": true,
          "pattern": "(?i).+\\.(png|svg|jpg|jpeg|webp)$"
        },
        "carrierLogo_fedex": {
          "type": "fileSelector",
          "label": { "en": "FedEx logo", "de": "FedEx-Logo" },
          "sm": 12, "md": 6, "lg": 4,
          "root": "dataFiles",
          "folder": "data:vis.0/main/img/parcelnet",
          "allowUpload": true,
          "pattern": "(?i).+\\.(png|svg|jpg|jpeg|webp)$"
        }
      }
    }
  }
}
