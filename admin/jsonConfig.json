{
  "type": "tabs",
  "items": {
    "mainTab": {
      "type": "panel",
      "label": {
        "en": "General",
        "de": "Allgemein"
      },
      "items": {
        "apiKey": {
          "type": "password",
          "label": {
            "en": "Parcel API key",
            "de": "Parcel API-Key"
          },
          "help": {
            "en": "Create the key at web.parcelapp.net.",
            "de": "Den Schlüssel erzeugst du unter web.parcelapp.net."
          },
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "filterMode": {
          "type": "select",
          "label": {
            "en": "Filter mode",
            "de": "Filtermodus"
          },
          "options": [
            {
              "label": {
                "en": "Active deliveries",
                "de": "Aktive Lieferungen"
              },
              "value": "active"
            },
            {
              "label": {
                "en": "Recent deliveries",
                "de": "Letzte Lieferungen"
              },
              "value": "recent"
            }
          ],
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "pollIntervalMinutes": {
          "type": "number",
          "label": {
            "en": "Polling interval (minutes)",
            "de": "Polling-Intervall (Minuten)"
          },
          "min": 3,
          "step": 1,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "requestTimeoutMs": {
          "type": "number",
          "label": {
            "en": "Request timeout (ms)",
            "de": "Request-Timeout (ms)"
          },
          "min": 5000,
          "step": 1000,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "maxItemsInHtml": {
          "type": "number",
          "label": {
            "en": "Max items in VIS HTML",
            "de": "Max. Einträge im VIS-HTML"
          },
          "min": 1,
          "step": 1,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "showTrackingNumberInHtml": {
          "type": "checkbox",
          "label": {
            "en": "Show tracking number in VIS HTML",
            "de": "Trackingnummer im VIS-HTML anzeigen"
          },
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "showDemoWhenEmpty": {
          "type": "checkbox",
          "label": {
            "en": "Show demo carriers when API returns no deliveries",
            "de": "Demo-Carrier anzeigen, wenn die API keine Sendungen liefert"
          },
          "help": {
            "en": "Only affects the VIS HTML states. Real delivery states stay empty.",
            "de": "Betrifft nur die VIS-HTML-States. Echte Liefer-States bleiben leer."
          },
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "logRawResponse": {
          "type": "checkbox",
          "label": {
            "en": "Log raw API response (debug)",
            "de": "Rohantwort der API loggen (Debug)"
          },
          "sm": 12,
          "md": 4,
          "lg": 3
        }
      }
    },
    "carrierTab": {
      "type": "panel",
      "label": {
        "en": "Carrier logos",
        "de": "Carrier-Logos"
      },
      "items": {
        "logoInfo": {
          "type": "staticText",
          "text": {
            "en": "Upload the logo files directly in this tab. The files are stored in the adapter file area parcelnet.%INSTANCE%.files/carriers. After upload, refresh the dropdown if needed and select the file.",
            "de": "Lade die Logo-Dateien direkt in diesem Reiter hoch. Die Dateien werden im Adapter-Dateibereich parcelnet.%INSTANCE%.files/carriers gespeichert. Nach dem Upload bei Bedarf das Auswahlfeld aktualisieren und die Datei auswählen."
          },
          "sm": 12,
          "md": 12,
          "lg": 12
        },
        "logoFolder": {
          "type": "staticText",
          "text": {
            "en": "Upload target: parcelnet.%INSTANCE%.files/carriers",
            "de": "Upload-Ziel: parcelnet.%INSTANCE%.files/carriers"
          },
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "carrierLogo_parcel": {
          "type": "file",
          "label": {
            "en": "Default / fallback logo",
            "de": "Standard-/Fallback-Logo"
          },
          "sm": 12,
          "md": 6,
          "lg": 4,
          "limitPath": "parcelnet.%INSTANCE%.files/carriers",
          "filterFiles": [
            "png",
            "svg",
            "jpg",
            "jpeg",
            "gif",
            "webp"
          ],
          "allowUpload": true,
          "allowDownload": true,
          "allowCreateFolder": false,
          "allowView": true,
          "showToolbar": true,
          "trim": true,
          "help": {
            "en": "Select or upload an image directly in the adapter file area under parcelnet.%INSTANCE%.files/carriers.",
            "de": "Bild direkt im Adapter-Dateibereich unter parcelnet.%INSTANCE%.files/carriers auswählen oder hochladen."
          }
        },
