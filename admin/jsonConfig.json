{
  "type": "tabs",
  "items": {
    "mainTab": {
      "type": "panel",
      "label": {
        "en": "General",
        "de": "Allgemein"
      },
      "items": {
        "apiKey": {
          "type": "password",
          "label": {
            "en": "Parcel API key",
            "de": "Parcel API-Key"
          },
          "help": {
            "en": "Create the key at web.parcelapp.net.",
            "de": "Den Schlüssel erzeugst du unter web.parcelapp.net."
          },
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "filterMode": {
          "type": "select",
          "label": {
            "en": "Filter mode",
            "de": "Filtermodus"
          },
          "options": [
            {
              "label": {
                "en": "Active deliveries",
                "de": "Aktive Lieferungen"
              },
              "value": "active"
            },
            {
              "label": {
                "en": "Recent deliveries",
                "de": "Letzte Lieferungen"
              },
              "value": "recent"
            }
          ],
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "pollIntervalMinutes": {
          "type": "number",
          "label": {
            "en": "Polling interval (minutes)",
            "de": "Polling-Intervall (Minuten)"
          },
          "min": 3,
          "step": 1,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "requestTimeoutMs": {
          "type": "number",
          "label": {
            "en": "Request timeout (ms)",
            "de": "Request-Timeout (ms)"
          },
          "min": 5000,
          "step": 1000,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "maxItemsInHtml": {
          "type": "number",
          "label": {
            "en": "Max items in VIS HTML",
            "de": "Max. Einträge im VIS-HTML"
          },
          "min": 1,
          "step": 1,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "showTrackingNumberInHtml": {
          "type": "checkbox",
          "label": {
            "en": "Show tracking number in VIS HTML",
            "de": "Trackingnummer im VIS-HTML anzeigen"
          },
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "showDemoWhenEmpty": {
          "type": "checkbox",
          "label": {
            "en": "Show demo carriers when API returns no deliveries",
            "de": "Demo-Carrier anzeigen, wenn die API keine Sendungen liefert"
          },
          "help": {
            "en": "Only affects the VIS HTML states. Real delivery states stay empty.",
            "de": "Betrifft nur die VIS-HTML-States. Echte Liefer-States bleiben leer."
          },
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "logRawResponse": {
          "type": "checkbox",
          "label": {
            "en": "Log raw API response (debug)",
            "de": "Rohantwort der API loggen (Debug)"
          },
          "sm": 12,
          "md": 4,
          "lg": 3
        }
      }
    },
    "carrierTab": {
      "type": "panel",
      "label": {
        "en": "Carrier logos",
        "de": "Carrier-Logos"
      },
      "items": {
        "logoInfo": {
          "type": "staticText",
          "text": {
            "en": "The direct upload field is disabled in this hotfix because it crashes in some Admin versions. Please upload files via the ioBroker file manager and paste the resulting path here, for example /adapter/parcelnet/carriers/dhl.svg or /vis.0/main/img/dhl.png.",
            "de": "Das direkte Upload-Feld ist in diesem Hotfix deaktiviert, weil es in manchen Admin-Versionen abstürzt. Bitte Dateien über den ioBroker-Dateimanager hochladen und den resultierenden Pfad hier eintragen, z. B. /adapter/parcelnet/carriers/dhl.svg oder /vis.0/main/img/dhl.png."
          },
          "sm": 12,
          "md": 12,
          "lg": 12
        },
        "logoFolder": {
          "type": "staticText",
          "text": {
            "en": "Supported paths: adapter file paths, VIS file paths or external HTTPS URLs.",
            "de": "Unterstützte Pfade: Adapter-Dateipfade, VIS-Dateipfade oder externe HTTPS-URLs."
          },
          "sm": 12,
          "md": 12,
          "lg": 12
        },
        "carrierLogo_parcel": {
          "type": "text",
          "label": {
            "en": "Default / fallback logo",
            "de": "Standard-/Fallback-Logo"
          },
          "help": {
            "en": "Path or URL to the logo image. Leave empty to use the built-in fallback.",
            "de": "Pfad oder URL zum Logobild. Leer lassen, um das eingebaute Fallback zu verwenden."
          },
          "placeholder": "/adapter/parcelnet/carriers/parcel.svg",
          "default": "",
          "trim": true,
