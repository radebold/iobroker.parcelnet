{
  "common": {
    "name": "parcelnet",
    "version": "0.7.0-beta.5",
    "news": {
      "0.5.0": {
        "en": "Initial TypeScript adapter version with Parcel API polling, item states, manual refresh and VIS HTML output.",
        "de": "Erste TypeScript-Adapterversion mit Parcel-API-Polling, Einzelzuständen, manuellem Refresh und VIS-HTML-Ausgabe."
      },
      "0.7.0-beta.5": {
        "en": "Version alignment hotfix: all package metadata synchronized to 0.7.0-beta.5.",
        "de": "Versionsabgleich-Hotfix: alle Paket-Metadaten auf 0.7.0-beta.5 synchronisiert."
      }
    },
    "titleLang": {
      "en": "ParcelNet",
      "de": "ParcelNet"
    },
    "desc": {
      "en": "Reads active or recent deliveries from Parcel App and exposes them as ioBroker states.",
      "de": "Liest aktive oder kürzliche Sendungen aus Parcel App und stellt sie als ioBroker-States bereit."
    },
    "authors": [
      "Thomas Radebold / OpenAI"
    ],
    "keywords": [
      "parcel",
      "deliveries",
      "tracking",
      "logistics"
    ],
    "platform": "Javascript/Node.js",
    "icon": "parcelnet.png",
    "enabled": true,
    "extIcon": "https://raw.githubusercontent.com/radebold/ioBroker.parcelnet/master/admin/parcelnet.png",
    "readme": "https://github.com/radebold/ioBroker.parcelnet/blob/master/README.md",
    "loglevel": "info",
    "mode": "daemon",
    "type": "misc-data",
    "compact": true,
    "connectionType": "cloud",
    "dataSource": "poll",
    "adminUI": {
      "config": "json"
    },
    "dependencies": [
      {
        "js-controller": ">=6.0.11"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=6.7.17"
      }
    ],
    "tier": 3,
    "licenseInformation": {
      "type": "free",
      "license": "MIT"
    }
  },
  "protectedNative": [
    "apiKey"
  ],
  "encryptedNative": [
    "apiKey"
  ],
  "native": {
    "apiKey": "",
    "filterMode": "active",
    "pollIntervalMinutes": 15,
    "requestTimeoutMs": 15000,
    "maxItemsInHtml": 10,
    "showTrackingNumberInHtml": true,
    "logRawResponse": false
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "Connected to Parcel API",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
