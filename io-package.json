{
  "common": {
    "name": "parcelnet",
    "version": "0.7.0-beta.1",
    "news": {
      "0.7.0-beta.1": {
        "en": "Public beta preparation: cleaned metadata, improved README, GitHub Actions workflow, beta checklist and current hotfixes included.",
        "de": "Vorbereitung für öffentliche Beta: bereinigte Metadaten, verbesserte README, GitHub-Actions-Workflow, Beta-Checkliste und aktuelle Hotfixes enthalten."
      }
    },
    "titleLang": {
      "en": "ParcelNet",
      "de": "ParcelNet"
    },
    "desc": {
      "en": "Reads active or recent deliveries from Parcel App and exposes them as ioBroker states.",
      "de": "Liest aktive oder kürzliche Sendungen aus Parcel App und stellt sie als ioBroker-States bereit."
    },
    "authors": [
      "Thomas Radebold",
      "OpenAI"
    ],
    "keywords": [
      "parcel",
      "deliveries",
      "tracking",
      "logistics"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "main": "main.js",
    "icon": "parcelnet.png",
    "enabled": true,
    "extIcon": "https://raw.githubusercontent.com/ioBroker/ioBroker.parcelnet/main/admin/parcelnet.png",
    "readme": "https://github.com/ioBroker/ioBroker.parcelnet/blob/main/README.md",
    "loglevel": "info",
    "mode": "daemon",
    "type": "communication",
    "compact": false,
    "connectionType": "cloud",
    "dataSource": "poll",
    "materialize": true,
    "adminUI": {
      "config": "json"
    },
    "dependencies": [
      {
        "js-controller": ">=3.3.0"
      }
    ],
    "title": "ParcelNet"
  },
  "protectedNative": [
    "apiKey"
  ],
  "encryptedNative": [
    "apiKey"
  ],
  "native": {
    "apiKey": "",
    "filterMode": "active",
    "pollIntervalMinutes": 15,
    "requestTimeoutMs": 15000,
    "maxItemsInHtml": 10,
    "showTrackingNumberInHtml": true,
    "logRawResponse": false,
    "showDemoWhenEmpty": true,
    "logoFolder": "parcelnet.%INSTANCE%.files/carriers",
    "carrierLogo_dhl": "",
    "carrierLogo_hermes": "",
    "carrierLogo_dpd": "",
    "carrierLogo_ups": "",
    "carrierLogo_amazon": "",
    "carrierLogo_gls": "",
    "carrierLogo_deutschepost": "",
    "carrierLogo_fedex": "",
    "carrierLogo_parcel": "",
    "_uiHotfix": "carrier-logo-text-inputs"
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "Connected to Parcel API",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ],
  "version": "0.6.3-hotfix21"
}
