{
  "name": "iobroker.parcelnet",
  "version": "0.7.0-beta.1",
  "description": "ioBroker adapter for Parcel App deliveries with VIS HTML output",
  "author": {
    "name": "Thomas Radebold",
    "email": ""
  },
  "homepage": "https://github.com/ioBroker/ioBroker.parcelnet",
  "license": "MIT",
  "keywords": [
    "iobroker",
    "parcel",
    "delivery",
    "tracking",
    "parcel.app"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ioBroker/ioBroker.parcelnet.git"
  },
  "engines": {
    "node": ">=16"
  },
  "main": "main.js",
  "files": [
    "admin/",
    "io-package.json",
    "main.js",
    "build/",
    "README.md",
    "LICENSE",
    ".github/",
    "docs/"
  ],
  "scripts": {
    "check:js": "node --check main.js",
    "check:json": "node -e \"JSON.parse(require('fs').readFileSync('io-package.json','utf8')); JSON.parse(require('fs').readFileSync('admin/jsonConfig.json','utf8')); console.log('json ok')\"",
    "test": "npm run check:js && npm run check:json",
    "pack": "npm pack"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.2.3"
  },
  "authors": [
    {
      "name": "Thomas Radebold"
    },
    {
      "name": "OpenAI",
      "url": "https://openai.com"
    }
  ],
  "bugs": {
    "url": "https://github.com/ioBroker/ioBroker.parcelnet/issues"
  }
